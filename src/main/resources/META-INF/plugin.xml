<idea-plugin>
    <id>com.github.yakov255.intellijphpmcp</id>
    <name>PHP MCP</name>
    <vendor>yakov255</vendor>
    <description><![CDATA[
        <p>MCP Server for PHP — finds symbol usages and references in PHP projects.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.mcpServer</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.github.yakov255.intellijphpmcp.mcp.PhpFindUsagesService"/>
        <projectService serviceImplementation="com.github.yakov255.intellijphpmcp.mcp.PhpContractInspectorService"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij.mcpServer">
        <mcpToolset implementation="com.github.yakov255.intellijphpmcp.mcp.PhpToolset"/>
    </extensions>
</idea-plugin>